{
  "name": "steel-orchestrator",
  "version": "0.1.0",
  "description": "Open-source multi-session orchestrator for Steel Browser, powered by Orb Cloud",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "tsx --test tests/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/websocket": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "ws": "^8.18.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13"
  }
}
