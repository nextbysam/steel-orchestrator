# Required: Orb Cloud API key
ORB_API_KEY=your_orb_api_key_here
ORB_API_URL=https://api.orbcloud.dev
ORB_TEMPLATE=steel-browser

# Orchestrator port
PORT=3000

# API keys for authenticating users (comma-separated)
# Empty = auth disabled (dev mode)
API_KEYS=sk_test_key1,sk_test_key2

# Per-key session limit (0 = unlimited)
MAX_SESSIONS_PER_KEY=50

# Session inactivity timeout (30 min)
SESSION_TIMEOUT_MS=1800000

# Warm pool config
WARM_POOL_MIN=2
WARM_POOL_MAX=10

# Max VM age before recycling (1 hour — Chrome memory leaks)
MAX_VM_AGE_MS=3600000

# Health check interval (30 seconds)
HEALTH_CHECK_INTERVAL_MS=30000

# Where to save session contexts for persistence
CONTEXT_STORE_PATH=./data/contexts
